{
  "name": "@ken-all/kenall",
  "version": "2.3.1",
  "description": "KENALL JavaScript SDK",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">= 20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./*": {
      "import": "./dist/*",
      "require": "./dist/cjs/*"
    }
  },
  "scripts": {
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check-format": "biome format src/",
    "build": "tsc -d && tsc -d -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > dist/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "bundle": "rollup -c",
    "test": "jest",
    "doc:gen-json": "typedoc --plugin typedoc-plugin-localization --generate-json translations/base",
    "doc:base": "typedoc --out dist/docs",
    "doc:ja": "typedoc --plugin typedoc-plugin-localization --out dist/docs/ja --readme README.ja.md --generate-from-json translations/ja"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ken-all/kenall-js.git"
  },
  "author": "Open Collector, Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ken-all/kenall-js/issues"
  },
  "homepage": "https://github.com/ken-all/kenall-js#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "jest": "^30.0.0",
    "rollup": "^4.60.0",
    "rollup-plugin-license": "^3.7.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.0",
    "typedoc-plugin-localization": "^3.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "zod": "^4.4.0"
  }
}
